```yaml
name: Daily Hotspot Monitor

on:
  schedule:
    - cron: '0 23 * * *'
  workflow_dispatch:

jobs:
  monitor:
    runs-on: ubuntu-latest
    steps:
    - uses: actions/checkout@v4
    - uses: actions/setup-python@v4
      with:
        python-version: '3.10'
    - run: pip install requests pyyaml
    - run: python scripts/generate-report.py
```
